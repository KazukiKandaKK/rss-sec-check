    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "private": true
}
