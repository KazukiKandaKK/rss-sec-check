# Firebase web app config (used in web/src/lib/firebase.ts)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Owner email (must match the one in firestore.rules and the Google account)
VITE_OWNER_EMAIL=owner@example.com

# Functions / emulator configuration (used in scripts)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
OWNER_EMAIL=owner@example.com

# Fetch schedule interval (used by onSchedule, default 30 minutes)
FETCH_SCHEDULE_INTERVAL=30
